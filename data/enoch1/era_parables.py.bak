            {"ref": "Revelation 22:5", "note": "'They will need no light of lamp or sun, for the Lord God will be their light' — the same Enochic motif", "type": "nt"},
            {"ref": "Isaiah 60:19-20", "note": "'The LORD will be your everlasting light' — the OT source for eternal divine light replacing sun and moon", "type": "ot"},
            {"ref": "John 8:12", "note": "'I am the light of the world' — Jesus as the embodiment of the Parables' 'light of eternal life'", "type": "nt"}
