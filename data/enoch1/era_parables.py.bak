            {"ref": "Revelation 11:1", "note": "'Rise and measure the temple of God' — the measuring-for-protection motif", "type": "nt"},
            {"ref": "Revelation 21:15-17", "note": "An angel measures the New Jerusalem — the eschatological measuring tradition", "type": "nt"}
        ],

        "divine_council_note": "The measuring angels take a census of the faithful — "
