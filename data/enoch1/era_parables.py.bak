    {
        "id": "1en-51",
        "ref": "1 Enoch 51",
        "chapter_num": 51,
        "title": "The Resurrection of the Dead — Sheol Gives Back Its Charge",
        "era": "parables",
        "type": "chapter",

        "synopsis": "The earth, Sheol, and hell give back the dead entrusted to them. "
                    "The Elect One arises and chooses the righteous from among the "
                    "resurrected dead. This is the most detailed pre-Christian "
                    "description of a general resurrection followed by messianic "
                    "judgment.",

