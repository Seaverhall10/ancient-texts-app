            {"ref": "Daniel 12:2", "note": "'Many who sleep in the dust shall awake' — the canonical seed text", "type": "ot"},
            {"ref": "John 5:28-29", "note": "'All who are in the tombs will hear his voice and come out' — echoes 1 Enoch 51", "type": "nt"},
            {"ref": "Matthew 25:32", "note": "The Son of Man separates sheep from goats — the same function as the Elect One's choosing", "type": "nt"}
