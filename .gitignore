# ══════════════════════════════════════════════════════
# Ancient Texts Study App — Git Ignore
# ══════════════════════════════════════════════════════

# ── Build Output ──────────────────────────────────────
# Generated by build.py / build_mobile.py / release.py
output/
releases/

# ── Electron ──────────────────────────────────────────
dist/
electron/node_modules/

# ── Python ────────────────────────────────────────────
venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/

# ── Secrets / API Keys ───────────────────────────────
agents/config.py
.env
*.key
*.pem

# ── Claude Code ───────────────────────────────────────
.claude/settings.local.json
.claude/plans/
.claude/todos/

# ── OS Files ──────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
nul

# ── IDE ───────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Archive (old/reference files) ────────────────────
archive/

# ── Stray mobile build files (if deploy fails) ──────
# These should ONLY live in output/mobile/
/index.html
/sw.js
/manifest.webmanifest
/icon-*.png
/icon-*.svg
/LAUNCH-MOBILE.bat
data/eras/*.json
data/interlinear/*.json
data/core_beliefs.json
data/glossary.json
data/prophecy.json
data/prophecy_tracker.json
data/resources.json
data/text_intros.json
data/manifest.json

# ── Misc ──────────────────────────────────────────────
lector_batch_summary.json
*.log
